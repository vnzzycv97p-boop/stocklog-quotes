name: Update Stock Quotes

on:
  schedule:
    # Runs at 21:30 UTC = 4:30 PM US Eastern (after NYSE/NASDAQ close at 4:00 PM ET)
    # Adjust this if you want a different time.
    - cron: '30 21 * * 1-5'
  # Allows you to run this manually from the Actions tab too
  workflow_dispatch:

permissions:
  contents: write

jobs:
  update-quotes:
    runs-on: ubuntu-latest
    steps:
      - name: Check out repo
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install dependencies
        run: pip install yfinance

      - name: Fetch quotes
        run: python fetch_quotes.py

      - name: Commit and push quotes.json
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add quotes.json
          git diff --quiet --cached || git commit -m "Update quotes $(date -u +'%Y-%m-%d %H:%M UTC')"
          git push
